# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=transactional_email_service
DB_SSLMODE=disable

# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_SENDER_EMAIL=noreply@yourdomain.com

# Retry config
MAX_RETRY_COUNT=3
RETRY_BASE_DELAY_MS=500
